{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Quality: Run all checks",
            "type": "process",
            "command": "uv",
            "args": [
                "run",
                "pre-commit",
                "run",
                "--all-files"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "Test: Run pytest",
            "type": "process",
            "command": "uv",
            "args": [
                "run",
                "pytest",
                "-v"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "GPU: Run CUDA verification",
            "type": "process",
            "command": "uv",
            "args": [
                "run",
                "python",
                "gpu_check.py"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        }
    ]
}
